// BEEPLUS Datenmodell (Postgres, mandantenfaehig).
//
// Mandantentrennung (siehe gymproject.md / Sicherheitsanforderung "ein Gym darf
// niemals Daten eines anderen Gyms sehen") wird auf zwei unabhaengigen Ebenen
// durchgesetzt:
//   1. Anwendungsebene: src/lib/scoped-prisma.ts erzwingt gymId auf jeder Query.
//   2. Datenbankebene: Row-Level-Security-Policies (siehe Migration
//      enable_row_level_security), die selbst bei einem Anwendungsfehler den
//      Zugriff auf fremde Zeilen verweigern.
// Deshalb tragen bewusst auch "Kind"-Tabellen (z.B. Booking, SepaDebit) eine
// eigene gymId-Spalte, obwohl sie sich theoretisch über eine Relation
// herleiten liesse - das macht RLS-Policies pro Tabelle trivial und
// unabhaengig von Joins.
//
// Enums sind als String-Spalten modelliert; erlaubte Werte stehen in
// src/lib/enums.ts als zod-Enums. Geldbetraege sind Int in Cent.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- Mandant + Plattform-Verwaltung -----------------------------------

model Gym {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  status       String   @default("ACTIVE") // GymStatus: ACTIVE | SUSPENDED
  contactEmail String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Branding (White-Label) - alle optional, ungesetzt faellt auf die
  // BEEPLUS-Standardmarke zurueck (siehe src/lib/branding.ts). Nur diese
  // Felder sind pro Gym einstellbar; Statusfarben, Abstaende, Radien und
  // Layout bleiben bewusst fest verdrahtet (Qualitaetsversprechen).
  logoUrl        String? // Standard-Logo (Upload)
  logoOnDarkUrl  String? // optionale Variante fuer dunkle Hintergruende (Sidebar, Login-Panel)
  logoOnLightUrl String? // optionale Variante fuer helle Hintergruende
  faviconUrl     String? // automatisch aus logoUrl generiert, nicht separat hochladbar
  loginClaim     String? // freier Text auf dem Login-Screen
  primaryColor   String? // Hex, z.B. "#e2483d" - einzige direkt gesetzte Markenfarbe
  accentColor    String? // Hex, optional, fuer Sekundaeres

  locations      Location[]
  employees      Employee[]
  customers      Customer[]
  contractPlans  ContractPlan[]
  voucherTypes   VoucherType[]
  courses        Course[]
  events         Event[]
  calendarEvents CalendarEvent[]
  bookings       Booking[]
  trials         Trial[]
  news           News[]
  emailTemplates EmailTemplate[]
  settings       Settings?
  employeePayouts     EmployeePayout[]
  customerBankAccounts CustomerBankAccount[]
  sepaDebits          SepaDebit[]
  contractDetails     ContractDetail[]
  voucherAssignments  VoucherAssignment[]
  trialProposedSlots  TrialProposedSlot[]
  newsAttachments     NewsAttachment[]
}

// Plattform-Betreiber-Konto (BEEPLUS-Betreiber, nicht Gym-Personal!) -
// bewusst ein eigenes Modell statt eines Flags auf Employee, damit ein
// Gym-Mitarbeiter niemals versehentlich plattformweiten Zugriff erhalten
// kann.
model PlatformAdmin {
  id           String   @id @default(cuid())
  firstName    String
  lastName     String
  email        String   @unique
  passwordHash String

  passwordResetToken     String?   @unique
  passwordResetExpiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- Gym-Stammdaten -----------------------------------------------------

model Location {
  id        String   @id @default(cuid())
  gymId     String
  gym       Gym      @relation(fields: [gymId], references: [id])
  city      String
  street    String
  zip       String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customers      Customer[]      @relation("CustomerLocations")
  employees      Employee[]      @relation("EmployeeLocations")
  courses        Course[]        @relation("CourseLocations")
  events         Event[]         @relation("EventLocations")
  calendarEvents CalendarEvent[]
  trials         Trial[]
  news           News[]          @relation("NewsLocations")
}

model Employee {
  id            String    @id @default(cuid())
  gymId         String
  gym           Gym       @relation(fields: [gymId], references: [id])
  firstName     String
  lastName      String
  gender        String // Gender: w | m
  birthday      DateTime
  employeeSince DateTime
  // Mehrfachauswahl statt Einzel-Standort (analog zu Customer.locations) -
  // ein Mitarbeiter kann z.B. an zwei Filialen unterrichten/arbeiten.
  locations     Location[] @relation("EmployeeLocations")
  street        String?
  zip           String?
  city          String?
  email         String    @unique
  phone         String?
  mobile        String?
  notes         String?
  photoUrl      String?

  // Login
  passwordHash String
  canLogin     Boolean @default(true)

  // Passwort-Vergessen
  passwordResetToken     String?   @unique
  passwordResetExpiresAt DateTime?

  // Bankkonto / Gehalt
  bankName        String?
  iban            String?
  bic             String?
  salaryCents     Int?
  paymentSchedule String? // PaymentSchedule: FIRST_OF_MONTH | FIFTEENTH_OF_MONTH

  // Berechtigungen (permAdmin übertrumpft/beinhaltet alle anderen, gilt
  // ausschliesslich innerhalb des eigenen Gyms)
  permAdmin          Boolean @default(false)
  permCalendar       Boolean @default(false)
  permTrials         Boolean @default(false)
  permVouchers       Boolean @default(false)
  permEmployees      Boolean @default(false)
  permCustomers      Boolean @default(false)
  permSepa           Boolean @default(false)
  permEmailTemplates Boolean @default(false)
  permNews           Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payouts     EmployeePayout[]
  leadCourses Course[]
}

model EmployeePayout {
  id          String   @id @default(cuid())
  gymId       String
  gym         Gym      @relation(fields: [gymId], references: [id])
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  amountCents Int
  date        DateTime
  status      String // PaymentStatus: OPEN | DONE
}

model Customer {
  id          String   @id @default(cuid())
  gymId       String
  gym         Gym      @relation(fields: [gymId], references: [id])
  firstName   String
  lastName    String
  gender      String // Gender: w | m
  birthday    DateTime
  street      String?
  houseNumber String?
  zip         String?
  city        String?
  // @unique gilt global (nicht nur pro Gym): die Mobile-App identifiziert
  // einen Login-Versuch per OTP ausschliesslich ueber die E-Mail, bevor die
  // gymId bekannt ist (siehe api/mobile/auth) - zwei Customer-Datensaetze mit
  // derselben E-Mail waeren dort nicht mehr eindeutig auflösbar. Kunden ohne
  // E-Mail (weiterhin erlaubt) haben schlicht keinen App-Zugang.
  email    String? @unique
  phone    String?
  mobile   String?
  notes    String?
  photoUrl String?

  status       String // CustomerStatus: ACTIVE | PAUSED | INACTIVE
  contractType String // ContractType: VOUCHER | CONTRACT | TRIAL
  // Standort-Zuordnung ist bewusst kein einzelner Pflicht-Standort mehr,
  // sondern Mehrfachauswahl (z.B. Mitglied trainiert an zwei Filialen) oder
  // pauschal "alle Standorte" ueber allLocations - letzteres schliesst auch
  // kuenftig neu angelegte Standorte automatisch mit ein, ohne dass Bestands-
  // kunden nachgepflegt werden muessen. Bei allLocations=true bleibt
  // `locations` leer/ungenutzt.
  allLocations Boolean    @default(false)
  locations    Location[] @relation("CustomerLocations")
  joinedAt     DateTime // Eintrittsdatum / "Beigetreten am"

  originTrialId String?
  originTrial   Trial?  @relation(fields: [originTrialId], references: [id])

  // Mobile-App-Login (Magic-Link/OTP, kein Passwort - siehe lib/core/otp.ts).
  // otpCodeHash statt Klartext, damit ein DB-Leak keine gueltigen Codes
  // preisgibt; otpAttempts begrenzt Brute-Force auf den kurzlebigen Code.
  otpCodeHash   String?
  otpExpiresAt  DateTime?
  otpAttempts   Int       @default(0)
  expoPushToken String? // fuer Warteliste-Promotion-Push, siehe lib/push.ts

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bankAccount CustomerBankAccount?
  sepaDebits  SepaDebit[]
  contract    ContractDetail?
  voucher     VoucherAssignment?
  bookings    Booking[]
}

model CustomerBankAccount {
  id                    String   @id @default(cuid())
  gymId                 String
  gym                   Gym      @relation(fields: [gymId], references: [id])
  customerId            String   @unique
  customer              Customer @relation(fields: [customerId], references: [id])
  bankName              String?
  iban                  String?
  bic                   String?
  directDebitAuthorized Boolean  @default(false)
  mandatePdfUrl         String?
}

model SepaDebit {
  id          String   @id @default(cuid())
  gymId       String
  gym         Gym      @relation(fields: [gymId], references: [id])
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])
  amountCents Int
  bookingDate DateTime
  status      String // PaymentStatus: OPEN | DONE
}

// Vertragsart (Mitgliedschafts-Plan) — pflegbar, definiert u.a. die max. Anzahl
// Kursbuchungen pro Woche. weeklyLimit == null bedeutet Flatrate (unbegrenzt).
model ContractPlan {
  id          String  @id @default(cuid())
  gymId       String
  gym         Gym     @relation(fields: [gymId], references: [id])
  name        String
  weeklyLimit Int?
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contracts ContractDetail[]
}

// Rohdaten + on-write neuberechnete Ergebnisse aus lib/core/cancellation.ts
model ContractDetail {
  id         String   @id @default(cuid())
  gymId      String
  gym        Gym      @relation(fields: [gymId], references: [id])
  customerId String   @unique
  customer   Customer @relation(fields: [customerId], references: [id])

  planId String
  plan   ContractPlan @relation(fields: [planId], references: [id])

  termMonths         Int // Laufzeit
  autoRenewalMonths  Int // aut. Verlängerung (Snapshot aus Settings bei Vertragsabschluss)
  noticePeriodMonths Int // Kündigungsfrist (Snapshot aus Settings)
  feeCents           Int // Beitrag
  debitOption        String // DebitOption: MONTHLY | WEEKLY

  pausedFrom             DateTime?
  pausedTo               DateTime?
  cancellationReceivedAt DateTime?

  // Berechnete Werte (aus calculateContractCancellation)
  contractEndDate           DateTime
  cancellationPossibleUntil DateTime
  cancellationEffectiveAt   DateTime
  autoRenewed               Boolean  @default(false)

  updatedAt DateTime @updatedAt
}

model VoucherType {
  id             String  @id @default(cuid())
  gymId          String
  gym            Gym     @relation(fields: [gymId], references: [id])
  label          String // z.B. "10er Karte"
  validityMonths Int
  sessionCount   Int
  priceCents     Int     @default(0)
  notes          String?

  assignments VoucherAssignment[]
}

model VoucherAssignment {
  id                String      @id @default(cuid())
  gymId             String
  gym               Gym         @relation(fields: [gymId], references: [id])
  customerId        String      @unique
  customer          Customer    @relation(fields: [customerId], references: [id])
  voucherTypeId     String
  voucherType       VoucherType @relation(fields: [voucherTypeId], references: [id])
  assignedAt        DateTime
  validUntil        DateTime
  remainingSessions Int
}

model Course {
  id               String    @id @default(cuid())
  gymId            String
  gym              Gym       @relation(fields: [gymId], references: [id])
  title            String
  description      String? // Kurzbeschreibung
  leadTrainerId    String
  leadTrainer      Employee  @relation(fields: [leadTrainerId], references: [id])
  participantLimit Int
  trialPossible    Boolean   @default(false)
  trialDate        DateTime?
  // Wie viele Stunden vor Kursbeginn ein Mitglied ueber die App noch stornieren
  // kann, ohne dass es als Nichterscheinen zaehlt. null = keine Frist (jederzeit
  // stornierbar). Pro Kurs statt global, da Studios das je nach Auslastung/
  // Trainer-Vorlaufzeit unterschiedlich handhaben wollen.
  cancellationCutoffHours Int?
  // null = globalen Standard aus Settings.defaultWaitlistLimit verwenden
  // (siehe settings.ts). Ueberschreibt diesen fuer den einzelnen Kurs.
  waitlistLimit Int?
  // null = globalen Standard aus Settings.defaultCourseDurationMinutes
  // verwenden. Dient nur als Vorbefuellung beim Anlegen neuer Kalendertermine
  // fuer diesen Kurs - die Dauer bleibt pro Termin frei änderbar.
  durationMinutes Int?

  locations          Location[]           @relation("CourseLocations")
  calendarEvents     CalendarEvent[]
  trialProposedSlots TrialProposedSlot[]
}

// Einmalige Veranstaltungen (z.B. Tag der offenen Tür, Wettkampf) - im
// Unterschied zu Course nicht an einen Trainer gebunden und nicht für
// Probetrainings vorgesehen, aber ebenfalls im Kalender terminierbar.
model Event {
  id               String  @id @default(cuid())
  gymId            String
  gym              Gym     @relation(fields: [gymId], references: [id])
  title            String
  description      String? // Kurzbeschreibung
  participantLimit Int

  locations      Location[]      @relation("EventLocations")
  calendarEvents CalendarEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CalendarEvent {
  id    String @id @default(cuid())
  gymId String
  gym   Gym    @relation(fields: [gymId], references: [id])
  // Genau eines von courseId/eventId ist gesetzt (in den Server Actions
  // validiert - Prisma bildet keine deklarative XOR-CHECK-Constraint ab).
  courseId   String?
  course     Course?  @relation(fields: [courseId], references: [id])
  eventId    String?
  event      Event?   @relation(fields: [eventId], references: [id])
  locationId String
  location   Location @relation(fields: [locationId], references: [id])
  startsAt   DateTime
  endsAt     DateTime
  capacity   Int

  // Gruppiert Termine, die aus einer wöchentlich wiederkehrenden Serie
  // generiert wurden (für späteres serienweites Bearbeiten/Löschen).
  seriesId String?

  bookings Booking[]
}

model Booking {
  id               String        @id @default(cuid())
  gymId            String
  gym              Gym           @relation(fields: [gymId], references: [id])
  calendarEventId  String
  calendarEvent    CalendarEvent @relation(fields: [calendarEventId], references: [id])
  customerId       String
  customer         Customer      @relation(fields: [customerId], references: [id])
  status           String // BookingStatus: BOOKED | WAITLISTED | CANCELLED
  waitlistPosition Int?
  createdAt        DateTime      @default(now())
}

model Trial {
  id         String   @id @default(cuid())
  gymId      String
  gym        Gym      @relation(fields: [gymId], references: [id])
  firstName  String
  lastName   String
  phone      String?
  email      String?
  locationId String
  location   Location @relation(fields: [locationId], references: [id])
  message    String?
  status     String // TrialStatus: OPEN | PROPOSED | ACCEPTED | DECLINED
  createdAt  DateTime @default(now())

  proposedSlots      TrialProposedSlot[]
  convertedCustomers Customer[]
}

model TrialProposedSlot {
  id          String    @id @default(cuid())
  gymId       String
  gym         Gym       @relation(fields: [gymId], references: [id])
  trialId     String
  trial       Trial     @relation(fields: [trialId], references: [id])
  startsAt    DateTime
  courseId    String?
  course      Course?   @relation(fields: [courseId], references: [id])
  token       String    @unique
  response    String    @default("PENDING") // TrialSlotResponse: PENDING | ACCEPTED | DECLINED
  respondedAt DateTime?
}

model News {
  id                 String    @id @default(cuid())
  gymId              String
  gym                Gym       @relation(fields: [gymId], references: [id])
  subject            String
  message            String
  sentAt             DateTime?
  status             String // NewsStatus: SENT | DRAFT | ARCHIVED
  publishOnWebsite   Boolean  @default(false)
  publishOnFacebook  Boolean  @default(false)
  publishOnInstagram Boolean  @default(false)
  createdAt          DateTime @default(now())

  locations   Location[]       @relation("NewsLocations")
  attachments NewsAttachment[]
}

model NewsAttachment {
  id       String @id @default(cuid())
  gymId    String
  gym      Gym    @relation(fields: [gymId], references: [id])
  newsId   String
  news     News   @relation(fields: [newsId], references: [id])
  fileName String
  url      String
}

model EmailTemplate {
  id        String   @id @default(cuid())
  gymId     String
  gym       Gym      @relation(fields: [gymId], references: [id])
  category  String // EmailTemplateCategory: PERSON | CALENDAR | BILLING
  label     String
  body      String // Text mit Platzhaltern, z.B. {{Vorname}}
  updatedAt DateTime @updatedAt
}

// 1 Zeile pro Gym (gymId ist zugleich Primärschlüssel statt Singleton-id=1
// wie im fruehen Single-Tenant-Entwurf).
model Settings {
  gymId String @id
  gym   Gym    @relation(fields: [gymId], references: [id])

  defaultNoticePeriodMonths Int @default(3)
  defaultAutoRenewalMonths  Int @default(3)

  // Vorschlagswerte fuer neue Kurse - pro Kurs ueberschreibbar (siehe
  // Course.waitlistLimit/durationMinutes). null bei defaultWaitlistLimit =
  // Warteliste standardmaessig unbegrenzt.
  defaultWaitlistLimit         Int?
  defaultCourseDurationMinutes Int  @default(60)

  // Social-Media-API-Zugangsdaten (Verwendung: News-Veröffentlichung, siehe Systeme-Seite)
  facebookPageId             String?
  facebookAccessToken        String?
  instagramBusinessAccountId String?
  instagramAccessToken       String?
}
